'use client';

import React from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import { Sparkles, Brain, Cpu, Wand2, CheckCircle2, Loader2, FileVideo } from 'lucide-react';

interface FusionViewProps {
  status: 'segmenting' | 'processing' | 'stitching' | 'completed' | 'failed';
  progress: number;
  segmentsCount: number;
  completedSegments: number;
  error?: string;
}

export const FusionView: React.FC<FusionViewProps> = ({
  status,
  progress,
  segmentsCount,
  completedSegments,
  error
}) => {
  const steps = [
    { id: 'segmenting', label: 'Video Segmentation', icon: FileVideo },
    { id: 'processing', label: 'AI Motion Transfer', icon: Brain },
    { id: 'stitching', label: 'FFmpeg Seamless Stitching', icon: Cpu },
  ];

  const getCurrentStepIndex = () => {
    if (status === 'segmenting') return 0;
    if (status === 'processing') return 1;
    if (status === 'stitching') return 2;
    if (status === 'completed') return 3;
    return -1;
  };

  const currentStepIdx = getCurrentStepIndex();

  return (
    <div className="h-full w-full flex flex-col items-center justify-center p-10 bg-[#050508]">
      <div className="max-w-2xl w-full flex flex-col items-center">
        
        {/* Animated AI Core */}
        <div className="relative w-48 h-48 mb-12">
          <motion.div 
            animate={{ 
              scale: [1, 1.2, 1],
              rotate: [0, 180, 360],
              opacity: [0.3, 0.6, 0.3]
            }}
            transition={{ duration: 10, repeat: Infinity, ease: "linear" }}
            className="absolute inset-0 bg-gradient-to-tr from-purple-600 to-blue-600 rounded-full blur-3xl"
          />
          <div className="absolute inset-0 flex items-center justify-center">
             <div className="w-32 h-32 rounded-full bg-black/40 backdrop-blur-2xl border border-white/10 flex items-center justify-center shadow-2xl relative z-10">
                {status === 'completed' ? (
                  <motion.div initial={{ scale: 0 }} animate={{ scale: 1 }}>
                    <CheckCircle2 className="text-green-500 w-16 h-16" />
                  </motion.div>
                ) : (
                  <Wand2 className="text-purple-400 w-12 h-12 animate-pulse" />
                )}
             </div>
          </div>
          
          {/* Orbiting particles */}
          <AnimatePresence>
            {status !== 'completed' && Array.from({ length: 3 }).map((_, i) => (
              <motion.div
                key={i}
                animate={{ 
                  rotate: [i * 120, i * 120 + 360],
                }}
                transition={{ duration: 3, repeat: Infinity, ease: "linear" }}
                className="absolute inset-0 pointer-events-none"
              >
                <div className="w-3 h-3 bg-white rounded-full absolute top-0 left-1/2 -translate-x-1/2 blur-sm" />
              </motion.div>
            ))}
          </AnimatePresence>
        </div>

        <h2 className="text-3xl font-black italic uppercase tracking-tighter text-white mb-4 text-center">
          {status === 'completed' ? 'Fusion Complete' : 'Synthesizing Archetypes'}
        </h2>
        
        <p className="text-white/40 text-[10px] font-black uppercase tracking-[0.3em] mb-12 text-center leading-relaxed">
          {status === 'processing' 
            ? `Processing AI Motion: ${completedSegments} of ${segmentsCount} segments`
            : steps.find(s => s.id === status)?.label || 'Initializing Engine'}
        </p>

        {/* Progress Steps */}
        <div className="w-full space-y-6">
          {steps.map((step, idx) => {
            const isDone = idx < currentStepIdx;
            const isCurrent = idx === currentStepIdx;
            
            return (
              <div key={step.id} className="relative">
                <div className="flex items-center gap-4 mb-2">
                   <div className={`w-8 h-8 rounded-xl flex items-center justify-center transition-all ${
                     isDone ? 'bg-green-500/20 text-green-500' : isCurrent ? 'bg-purple-600 text-white shadow-[0_0_20px_rgba(168,85,247,0.4)]' : 'bg-white/5 text-white/20'
                   }`}>
                      {isDone ? <CheckCircle2 size={16}/> : isCurrent ? <Loader2 size={16} className="animate-spin" /> : <step.icon size={16}/>}
                   </div>
                   <div className="flex-1">
                      <div className={`text-[10px] font-black uppercase tracking-widest ${isDone ? 'text-green-500' : isCurrent ? 'text-white' : 'text-white/20'}`}>
                        {step.label}
                      </div>
                      {isCurrent && (
                        <div className="w-full h-1 bg-white/5 rounded-full mt-2 overflow-hidden">
                           <motion.div 
                             initial={{ width: 0 }}
                             animate={{ width: `${progress}%` }}
                             className="h-full bg-gradient-to-r from-purple-600 to-blue-600"
                           />
                        </div>
                      )}
                   </div>
                </div>
              </div>
            );
          })}
        </div>

        {error && (
          <motion.div 
            initial={{ opacity: 0, y: 10 }}
            animate={{ opacity: 1, y: 0 }}
            className="mt-12 p-4 rounded-2xl bg-red-500/10 border border-red-500/20 text-red-400 text-[10px] font-bold uppercase tracking-widest text-center"
          >
            Error: {error}
          </motion.div>
        )}
      </div>
    </div>
  );
};
