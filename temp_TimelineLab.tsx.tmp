'use client';

import React, { useState, useRef, useEffect } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import { 
  Play, Pause, Scissors, UserPlus, 
  Sparkles, ChevronRight, Wand2, Clock,
  Trash2, Layers
} from 'lucide-react';

interface Segment {
  id: string;
  startTime: number;
  endTime: number;
  avatarUrl?: string;
  label: string;
}

interface TimelineLabProps {
  videoUrl: string;
  projectId: string;
  onGenerate: (segments: Segment[]) => void;
  onBack: () => void;
  availableAvatars: any[];
}

export const TimelineLab: React.FC<TimelineLabProps> = ({
  videoUrl,
  projectId,
  onGenerate,
  onBack,
  availableAvatars
}) => {
  const [isPlaying, setIsPlaying] = useState(false);
  const [currentTime, setCurrentTime] = useState(0);
  const [duration, setDuration] = useState(0);
  const [segments, setSegments] = useState<Segment[]>([]);
  const [selectedSegmentId, setSelectedSegmentId] = useState<string | null>(null);
  const [isSelectingRange, setIsSelectingRange] = useState(false);
  const [rangeStart, setRangeStart] = useState(0);
  
  const videoRef = useRef<HTMLVideoElement>(null);
  const timelineRef = useRef<HTMLDivElement>(null);

  // Initialize with a default full-video segment if empty
  useEffect(() => {
    if (duration > 0 && segments.length === 0) {
      setSegments([{
        id: 'default',
        startTime: 0,
        endTime: duration,
        label: 'Original Performance'
      }]);
    }
  }, [duration]);

  const togglePlay = () => {
    if (videoRef.current) {
      if (isPlaying) videoRef.current.pause();
      else videoRef.current.play();
      setIsPlaying(!isPlaying);
    }
  };

  const handleTimeUpdate = () => {
    if (videoRef.current) {
      setCurrentTime(videoRef.current.currentTime);
    }
  };

  const handleLoadedMetadata = () => {
    if (videoRef.current) {
      setDuration(videoRef.current.duration);
    }
  };

  const handleTimelineClick = (e: React.MouseEvent) => {
    if (!timelineRef.current) return;
    const rect = timelineRef.current.getBoundingClientRect();
    const x = e.clientX - rect.left;
    const percentage = x / rect.width;
    const time = percentage * duration;
    
    if (videoRef.current) {
      videoRef.current.currentTime = time;
      setCurrentTime(time);
    }
  };

  const addSegmentAtCurrentTime = (avatarUrl?: string, label: string = 'New Persona') => {
    const newSegment: Segment = {
      id: Math.random().toString(36).substr(2, 9),
      startTime: currentTime,
      endTime: Math.min(currentTime + 5, duration),
      avatarUrl,
      label
    };
    setSegments([...segments, newSegment]);
    setSelectedSegmentId(newSegment.id);
  };

  return (
    <div className="h-full w-full flex flex-col bg-[#050508] text-white">
      {/* Header */}
      <div className="p-6 flex items-center justify-between border-b border-white/5">
        <div className="flex items-center gap-4">
          <button onClick={onBack} className="p-2 hover:bg-white/5 rounded-xl text-white/40"><Trash2 size={20}/></button>
          <div>
            <h2 className="text-xl font-black italic uppercase tracking-widest text-white flex items-center gap-2">
              <Layers className="text-purple-500" size={18}/>
              Timeline Lab
            </h2>
            <p className="text-[10px] font-bold uppercase text-white/20 tracking-tighter">Assign Archetypes to Time Segments</p>
          </div>
        </div>

        <button 
          onClick={() => onGenerate(segments)}
          className="px-8 py-3 rounded-full bg-gradient-to-r from-purple-600 to-blue-600 font-black uppercase italic tracking-widest text-xs shadow-lg shadow-purple-900/40 active:scale-95 transition-all flex items-center gap-2"
        >
          Generate Fusion
          <Wand2 size={16} />
        </button>
      </div>

      <div className="flex-1 flex flex-col min-h-0 p-8 gap-8">
        {/* Main Content: Video + Avatar Dock */}
        <div className="flex-1 flex gap-8 min-h-0">
          {/* Video Preview */}
          <div className="flex-1 relative bg-black rounded-[2.5rem] overflow-hidden border border-white/10 shadow-2xl flex items-center justify-center">
            <video 
              ref={videoRef}
              src={videoUrl}
              onTimeUpdate={handleTimeUpdate}
              onLoadedMetadata={handleLoadedMetadata}
              className="max-h-full max-w-full object-contain"
            />
            
            {/* Play/Pause Overlay */}
            <div 
              className="absolute inset-0 flex items-center justify-center bg-black/20 opacity-0 hover:opacity-100 transition-opacity cursor-pointer"
              onClick={togglePlay}
            >
              <div className="w-20 h-20 rounded-full bg-white/10 backdrop-blur-md border border-white/20 flex items-center justify-center">
                {isPlaying ? <Pause size={40}/> : <Play size={40} className="translate-x-1"/>}
              </div>
            </div>

            {/* Time HUD */}
            <div className="absolute top-6 left-6 px-4 py-2 bg-black/60 backdrop-blur-md rounded-full border border-white/10 text-[10px] font-black tracking-widest">
              {currentTime.toFixed(2)}s / {duration.toFixed(2)}s
            </div>
          </div>

          {/* Avatar Dock (Vertical in this layout) */}
          <div className="w-64 flex flex-col gap-4">
            <h3 className="text-[10px] font-black uppercase tracking-widest text-white/30 px-2">Archetype Deck</h3>
            <div className="flex-1 overflow-y-auto pr-2 space-y-3 scrollbar-none">
              {availableAvatars.map((avatar) => (
                <motion.button
                  key={avatar.id}
                  whileHover={{ scale: 1.02, x: 5 }}
                  onClick={() => addSegmentAtCurrentTime(avatar.url, avatar.label)}
                  className="w-full flex items-center gap-3 p-3 rounded-2xl bg-white/5 border border-white/5 hover:bg-white/10 hover:border-purple-500/30 transition-all text-left group"
                >
                  <div className="w-12 h-12 rounded-xl bg-neutral-800 overflow-hidden border border-white/5 group-hover:border-purple-500/50">
                    <img src={avatar.url} className="w-full h-full object-cover" />
                  </div>
                  <div className="flex-1 min-w-0">
                    <div className="text-[10px] font-black uppercase text-white/60 truncate">{avatar.label}</div>
                    <div className="text-[8px] text-white/20 uppercase font-bold tracking-tighter">Click to Swap At {currentTime.toFixed(1)}s</div>
                  </div>
                  <UserPlus size={14} className="text-white/10 group-hover:text-purple-400"/>
                </motion.button>
              ))}
            </div>
          </div>
        </div>

        {/* Timeline Scrubber Area */}
        <div className="h-48 flex flex-col gap-4">
          <div className="flex items-center justify-between px-2">
            <div className="flex items-center gap-6">
              <div className="flex items-center gap-2">
                <Clock size={14} className="text-white/20"/>
                <span className="text-[10px] font-black text-white/40 uppercase tracking-widest">Master Timeline</span>
              </div>
            </div>
          </div>

          {/* The Actual Scrubber */}
          <div 
            ref={timelineRef}
            onClick={handleTimelineClick}
            className="relative h-24 bg-white/5 rounded-2xl border border-white/10 cursor-crosshair overflow-hidden group"
          >
            {/* Waveform Placeholder (will be replaced by actual SVG waveform later) */}
            <div className="absolute inset-0 flex items-end gap-0.5 px-1 opacity-20 group-hover:opacity-30 transition-opacity">
              {Array.from({ length: 150 }).map((_, i) => (
                <div 
                  key={i} 
                  className="flex-1 bg-white" 
                  style={{ height: `${Math.random() * 80 + 10}%` }} 
                />
              ))}
            </div>

            {/* Segments Display */}
            {segments.map((seg) => (
              <div
                key={seg.id}
                className={`absolute top-0 bottom-0 border-x border-white/10 flex flex-col justify-end p-2 transition-all ${
                  selectedSegmentId === seg.id ? 'bg-purple-500/20 z-10' : 'bg-white/5'
                }`}
                style={{
                  left: `${(seg.startTime / duration) * 100}%`,
                  width: `${((seg.endTime - seg.startTime) / duration) * 100}%`
                }}
              >
                {seg.avatarUrl && (
                  <div className="w-6 h-6 rounded-md overflow-hidden border border-white/20 mb-1">
                    <img src={seg.avatarUrl} className="w-full h-full object-cover" />
                  </div>
                )}
                <div className="text-[8px] font-black uppercase truncate text-white/40">{seg.label}</div>
              </div>
            ))}

            {/* Current Time Indicator */}
            <motion.div 
              className="absolute top-0 bottom-0 w-0.5 bg-red-500 shadow-[0_0_15px_rgba(239,68,68,0.8)] z-20 pointer-events-none"
              style={{ left: `${(currentTime / duration) * 100}%` }}
            >
              <div className="w-3 h-3 rounded-full bg-red-500 absolute -top-1 -left-[5px] border border-black shadow-lg" />
            </motion.div>
          </div>
        </div>
      </div>
    </div>
  );
};
